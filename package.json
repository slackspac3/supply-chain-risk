{
  "name": "risk-calculator",
  "version": "0.10.0-pilot.1",
  "private": true,
  "scripts": {
    "check:syntax": "node scripts/syntax-check.js",
    "check:smoke": "node scripts/smoke-check.js",
    "test:e2e": "playwright test",
