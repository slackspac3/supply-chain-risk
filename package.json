{
  "name": "risk-calculator",
  "version": "0.10.0-pilot.1",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "check:syntax": "node scripts/syntax-check.js",
    "check:smoke": "node scripts/smoke-check.js",
    "check:taxonomy-projection": "node scripts/sync-scenario-taxonomy-projection.js --check",
    "sync:taxonomy-projection": "node scripts/sync-scenario-taxonomy-projection.js --write",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.js",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:eval:fixture": "node --test tests/unit/scenarioEvalHarness.test.js",
    "eval:local": "node scripts/run-eval-local.js",
    "eval:ai": "node scripts/run-eval-ai.js",
    "eval:harvest": "node scripts/harvest-eval-growth-candidates.js",
    "release:pilot": "npm run check:syntax && npm run test:unit && npm run check:smoke && npm run test:e2e:smoke"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2"
  }
}
