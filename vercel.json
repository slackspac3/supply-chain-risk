{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://supply-chain-risk-two.vercel.app; worker-src 'self' blob:; img-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "functions": {
    "api/compass.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/company-context.js": {
      "memory": 256,
      "maxDuration": 60
    },
    "api/users.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/settings.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/user-state.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/audit-log.js": {
      "memory": 256,
      "maxDuration": 15
    }
  }
}
