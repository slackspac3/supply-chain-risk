# Frontend origins allowed to call the Vercel API routes.
# Required for pilot/staging. Use ALLOWED_ORIGINS for multiple comma-separated entries.
ALLOWED_ORIGIN="https://your-frontend-origin.example"
ALLOWED_ORIGINS="https://your-frontend-origin.example,https://your-second-origin.example"

# Live Compass / Core42 model access used by the API proxy and company-context builder.
# Required anywhere live AI quality matters.
COMPASS_API_KEY="__REPLACE_WITH_REAL_VALUE__"
COMPASS_API_URL="https://api.core42.ai/v1/chat/completions"
COMPASS_MODEL="gpt-5.1"

# Optional eval-harness overrides. Leave blank to reuse COMPASS_*.
RC_COMPASS_API_KEY=""
RC_COMPASS_API_URL=""
RC_COMPASS_MODEL=""

# Session and privileged admin secrets. Required for authenticated API use.
ADMIN_API_SECRET="__REPLACE_WITH_REAL_VALUE__"
SESSION_SIGNING_SECRET="__REPLACE_WITH_REAL_VALUE__"

# Shared KV-backed stores. Set one URL/token pair for the live shared store.
USER_STORE_KV_URL="__REPLACE_WITH_REAL_VALUE__"
USER_STORE_KV_TOKEN="__REPLACE_WITH_REAL_VALUE__"

# Compatibility aliases still supported by the current codebase.
RC_USER_STORE_URL=""
RC_USER_STORE_TOKEN=""
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
APPLE_CAT=""
BANANA_DOG=""
FOO_URL_TEST=""
FOO_TOKEN_TEST=""

# Storage keys and prefixes. Optional unless you need non-default names.
USER_STORE_KEY="risk_calculator_users"
SETTINGS_STORE_KEY="risk_calculator_settings"
USER_STATE_PREFIX="risk_calculator_user_state"
AUDIT_LOG_KEY="risk_calculator_audit_log"
AUDIT_LOG_CAPACITY="200"

# Bootstrap-only fallback account seed for empty user stores.
# Optional and recommended only for pilot seeding.
BOOTSTRAP_ACCOUNTS_JSON='[{"username":"admin","password":"__REPLACE_WITH_REAL_VALUE__","displayName":"Global Admin","role":"admin"}]'
